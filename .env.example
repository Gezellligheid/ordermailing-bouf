# ── Email provider ────────────────────────────────────────────────────────────
# Options: gmail | outlook | microsoft365
EMAIL_PROVIDER=outlook

# ── SMTP credentials ──────────────────────────────────────────────────────────
SMTP_USER=you@yourdomain.com
SMTP_PASS=your-password-or-app-password

# ── Shop info (used in order emails) ─────────────────────────────────────────
SHOP_NAME=Your Shop Name
SHOP_EMAIL=you@yourdomain.com
SHOP_PHONE=+32 000 00 00 00
SHOP_ADDRESS=Streetname 1, 0000 City
SHOP_VAT_NUMBER=BE0000000000

# ── Firebase client (public) ──────────────────────────────────────────────────
PUBLIC_ENV__FIREBASE_API_KEY=your-api-key
PUBLIC_ENV__FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
PUBLIC_ENV__FIREBASE_PROJECT_ID=your-project-id
PUBLIC_ENV__FIREBASE_STORAGE_BUCKET=your-project.appspot.com
PUBLIC_ENV__FIREBASE_MESSAGING_SENDER_ID=000000000000
PUBLIC_ENV__FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx

# ── Firebase Admin (service account) ─────────────────────────────────────────
FIREBASE_SA_TYPE=service_account
FIREBASE_SA_PROJECT_ID=your-project-id
FIREBASE_SA_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_SA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_SA_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_SA_CLIENT_ID=000000000000000000000
FIREBASE_SA_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_SA_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_SA_AUTH_PROVIDER_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_SA_CLIENT_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxxx%40your-project.iam.gserviceaccount.com
FIREBASE_SA_UNIVERSE_DOMAIN=googleapis.com
